# Q&A App Configuration

# Data storage path (default: /home/workspace/qa-app/data/qa-store.json)
QA_DATA_FILE=/home/workspace/qa-app/data/qa-store.json

# Admin token for protected endpoints (default: none - admin is open)
# Set this to secure admin actions like reset and merge
QA_ADMIN_TOKEN=your-secret-token-here
